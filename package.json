{
  "name": "neatnote",
  "version": "1.0.5",
  "description": "A lightweight note-taking application",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "prebuild:cleanup": "node build-cleanup.js",
    "build": "npm run prebuild:cleanup && electron-builder",
    "build:mac": "npm run prebuild:cleanup && electron-builder --mac",
    "build:win": "npm run prebuild:cleanup && electron-builder --win",
    "build:linux": "npm run prebuild:cleanup && electron-builder --linux"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.3",
    "pkg": "^5.8.1"
  },
  "build": {
    "appId": "com.example.neatnote",
    "productName": "NeatNote",
    "files": [
      "src/**/*",
      "assets/**/*",
      "index.html"
    ],
    "extraResources": [
      {
        "from": "dist/cleanup.exe",
        "to": "cleanup.exe",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NeatNote",
      "uninstallDisplayName": "NeatNote",
      "artifactName": "NeatNote-Setup-${version}.exe",
      "include": "installer/win/custom-installer.nsh"
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  }
}
